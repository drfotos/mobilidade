# ─── Supabase ──────────────────────────────────────────────
# Get these from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF

# ─── App URLs ───────────────────────────────────────────────
NEXT_PUBLIC_LANDING_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_GLOBAL_URL=http://localhost:3001
NEXT_PUBLIC_ADMIN_COMPANY_URL=http://localhost:3002
NEXT_PUBLIC_DRIVER_PWA_URL=http://localhost:3003
NEXT_PUBLIC_PASSENGER_PWA_URL=http://localhost:3004

# ─── Mapas (Free) ──────────────────────────────────────────
NEXT_PUBLIC_MAP_PROVIDER=osm
NEXT_PUBLIC_OSRM_URL=https://router.project-osrm.org
NEXT_PUBLIC_NOMINATIM_URL=https://nominatim.openstreetmap.org

# ─── Mercado Pago (optional in MVP) ────────────────────────
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=

# ─── OneSignal Push (optional in MVP) ──────────────────────
NEXT_PUBLIC_ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# ─── Resend Email (optional in MVP) ────────────────────────
RESEND_API_KEY=
EMAIL_FROM=no-reply@resend.dev

# ─── Super Admin ───────────────────────────────────────────
SUPER_ADMIN_EMAIL=portaldrfotos@gmail.com
